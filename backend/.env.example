# Application
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# Database (async driver required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_telecaller

# Auth (JWT_SECRET must be at least 32 random bytes)
JWT_SECRET=change-me-in-production-min-32-byte-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# AI providers
GEMINI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=

# Uploads
UPLOAD_DIRECTORY=uploads
MAX_UPLOAD_SIZE=10485760

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000"]
